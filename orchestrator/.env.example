# Orchestrator environment — copy to `.env` and fill in. Never commit real secrets.
# Load it however you run the app, e.g.:  set -a; source .env; set +a
#
# THIS FILE IS FOR LOCAL DEV ONLY. On Posit Connect Cloud, do NOT deploy a .env:
# set these same variable names as encrypted Environment Variables / Secrets on the
# content's Advanced settings tab. Connect injects them at runtime; the app reads
# everything via os.environ, so no key ever lives in the code or the deploy bundle.

# --- Run mode ---------------------------------------------------------------
# Baseline for every seam: offline (in-memory fakes) | live (real adapters).
ORCHESTRATOR_MODE=offline
# Per-seam overrides (optional) — bring one seam up at a time. Each: offline|live.
# To make real OpenRouter calls locally while storage/email stay in-memory:
#   ORCHESTRATOR_MODE=offline + GATEWAY_MODE=live
GATEWAY_MODE=live
# DATASTORE_MODE=live
# EMAILER_MODE=live

# --- Model gateway: OpenRouter (dev/test) -----------------------------------
OPENROUTER_API_KEY=sk-or-...                 # required for GATEWAY_MODE=live
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Single-provider (Anthropic) to start; override model ids if needed:
# INTAKE_CONVERSATION_MODEL=anthropic/claude-sonnet-4.6
# INTAKE_EXTRACTION_MODEL=anthropic/claude-haiku-4.5
# OPENROUTER_HTTP_REFERER=
# OPENROUTER_APP_TITLE=tool-request-orchestrator

# --- Operational datastore: Airtable (DATASTORE_MODE=live) -------------------
# AIRTABLE_API_KEY=
# AIRTABLE_BASE_ID=
# AIRTABLE_TABLE_TRANSCRIPTS=Transcripts
# AIRTABLE_TABLE_RECORDS=Records
# AIRTABLE_TABLE_STATE=State
# AIRTABLE_TABLE_EVENTS=Events

# --- Email: Resend (EMAILER_MODE=live) --------------------------------------
# RESEND_API_KEY=
# RESEND_FROM=workflow@yourdomain.com

# --- Console auth + notifications -------------------------------------------
# AI Enabler login (no real secrets in code; set this for any shared use):
# AUTH_USERS=enabler:CHANGE_ME:ai_enabler:AI Enabler
# SESSION_SECRET=CHANGE_ME
AI_ENABLER_EMAIL=you@yourdomain.com          # where gate prompts are sent
CONSOLE_BASE_URL=http://localhost:8000       # used for links in outbound email

# --- Capability registry (stack-check reads it when GATEWAY_MODE=live) -------
# REGISTRY_PATH=/path/to/registry/checkout
